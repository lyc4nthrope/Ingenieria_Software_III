{
  "annotations": { "list": [] },
  "description": "Dashboard de métricas de calidad para NØSEE — Plan ISO/IEC 25010",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Proceso 1 — Gestión de Usuario y Autenticación",
      "type": "row"
    },

    {
      "id": 1,
      "title": "Tasa de Éxito de Login",
      "description": "Sección 3.3.1 — Meta: >99.9%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green",  "value": 99.9 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * rate(nosee_auth_login_total{result=\"success\"}[5m]) / (rate(nosee_auth_login_total[5m]) > 0)",
          "legendFormat": "Tasa Éxito Login",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Latencia JWT — P95",
      "description": "Sección 3.4.1 — Meta: <800ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 2000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 600 },
              { "color": "red",    "value": 800 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(nosee_auth_login_duration_ms_bucket[5m]))",
          "legendFormat": "JWT Latency P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Tasa de Abandono en Login",
      "description": "RNF 4.3.5 — Meta: <5%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * rate(nosee_auth_login_abandons_total[1h]) / (rate(nosee_auth_login_page_views_total[1h]) > 0)",
          "legendFormat": "% Abandono Login",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Tiempo de Registro — P95",
      "description": "Sección 3.4.1 — Meta: <45s",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 45 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(nosee_auth_register_duration_seconds_bucket[1h]))",
          "legendFormat": "Registro P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Intentos de Login — Historial",
      "description": "Éxitos vs Fallos en el tiempo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fallos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Éxitos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(nosee_auth_login_total{result=\"success\"}[5m])",
          "legendFormat": "Éxitos",
          "refId": "A"
        },
        {
          "expr": "rate(nosee_auth_login_total{result=\"failure\"}[5m])",
          "legendFormat": "Fallos",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "title": "Errores de Roles + Recuperación de Contraseña",
      "description": "Integridad de Asignación de Roles (meta: 0 errores) y Efectividad de Recuperación (meta: >95%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "increase(nosee_auth_role_errors_total[24h])",
          "legendFormat": "Errores de Rol (24h)",
          "refId": "A"
        },
        {
          "expr": "100 * rate(nosee_auth_password_recovery_total{result=\"success\"}[7d]) / (rate(nosee_auth_password_recovery_total[7d]) > 0)",
          "legendFormat": "% Recuperación Exitosa (7d)",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Proceso 2 — Gestión de Publicaciones de Precios",
      "type": "row"
    },

    {
      "id": 7,
      "title": "Índice de Veracidad (Upvote Ratio)",
      "description": "Sección 3.4.2 — Meta: >85%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green",  "value": 0.85 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "nosee_publications_upvote_ratio",
          "legendFormat": "Upvote Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "Densidad de Evidencia Visual",
      "description": "Sección 3.4.2 — Meta: >60% con foto",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green",  "value": 0.6 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "nosee_publications_evidence_ratio",
          "legendFormat": "Evidence Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "Publicaciones Creadas (24h)",
      "description": "Total de publicaciones en las últimas 24 horas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "increase(nosee_publications_created_total[24h])",
          "legendFormat": "Publicaciones",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "Contenido Denunciado (24h)",
      "description": "Tasa de Contenido Denunciado — Meta: <5% de activas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "increase(nosee_publications_reports_total[24h])",
          "legendFormat": "Reportes",
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "title": "Total de Votos (24h)",
      "description": "Upvotes vs Downvotes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Downvotes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "increase(nosee_publications_votes_total{type=\"upvote\"}[24h])",
          "legendFormat": "Upvotes",
          "refId": "A"
        },
        {
          "expr": "increase(nosee_publications_votes_total{type=\"downvote\"}[24h])",
          "legendFormat": "Downvotes",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "title": "Votos en el Tiempo",
      "description": "Upvotes vs Downvotes — Velocidad de Consenso Comunitario",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Downvotes/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Upvotes/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(nosee_publications_votes_total{type=\"upvote\"}[5m])",
          "legendFormat": "Upvotes/s",
          "refId": "A"
        },
        {
          "expr": "rate(nosee_publications_votes_total{type=\"downvote\"}[5m])",
          "legendFormat": "Downvotes/s",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 102,
      "title": "Eficiencia de Desempeño — API",
      "type": "row"
    },

    {
      "id": 13,
      "title": "Latencia API — P95 por Endpoint",
      "description": "Sección 3.2 — Meta: <3000ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 5000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red",    "value": 3000 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(nosee_api_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "title": "Latencia API — Historial",
      "description": "Percentiles P50, P95, P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(nosee_api_request_duration_ms_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(nosee_api_request_duration_ms_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(nosee_api_request_duration_ms_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    }

  ],

  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Fuente de datos"
      }
    ]
  },

  "refresh": "15s",
  "schemaVersion": 37,
  "tags": ["nosee", "iso25010", "calidad"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NØSEE — Métricas de Calidad ISO/IEC 25010",
  "uid": "nosee-quality-iso25010",
  "version": 1
}
