{
  "annotations": { "list": [] },
  "description": "Dashboard de métricas de calidad para NØSEE — Plan ISO/IEC 25010",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Proceso 1 — Gestión de Usuario y Autenticación",
      "type": "row"
    },

    {
      "id": 1,
      "title": "Tasa de Éxito de Login",
      "description": "Sección 3.3.1 — Meta: >99.9%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green",  "value": 99.9 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * sum(nosee_auth_login_total{result=\"success\"}) / (sum(nosee_auth_login_total) > 0)",
          "legendFormat": "Tasa Éxito Login",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Latencia JWT — P95",
      "description": "Sección 3.4.1 — Meta: <800ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 2000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 600 },
              { "color": "red",    "value": 800 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (increase(nosee_auth_login_duration_ms_bucket[24h])))",
          "legendFormat": "JWT Latency P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Tasa de Abandono en Login",
      "description": "RNF 4.3.5 — Meta: <5%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * sum(nosee_auth_login_abandons_total) / (sum(nosee_auth_login_page_views_total) > 0)",
          "legendFormat": "% Abandono Login",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Tiempo de Registro — P95",
      "description": "Sección 3.4.1 — Meta: <45s",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 45 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (increase(nosee_auth_register_duration_seconds_bucket[24h])))",
          "legendFormat": "Registro P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Intentos de Login — Historial",
      "description": "Éxitos vs Fallos en el tiempo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fallos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Éxitos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(nosee_auth_login_total{result=\"success\"}[1h])",
          "legendFormat": "Éxitos",
          "refId": "A"
        },
        {
          "expr": "increase(nosee_auth_login_total{result=\"failure\"}[1h])",
          "legendFormat": "Fallos",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "title": "Errores de Roles + Recuperación de Contraseña",
      "description": "Integridad de Asignación de Roles (meta: 0 errores) y Efectividad de Recuperación (meta: >95%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(nosee_auth_role_errors_total) or vector(0)",
          "legendFormat": "Errores de Rol (total)",
          "refId": "A"
        },
        {
          "expr": "100 * sum(nosee_auth_password_recovery_total{result=\"success\"}) / (sum(nosee_auth_password_recovery_total) > 0)",
          "legendFormat": "% Recuperación Exitosa",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Proceso 2 — Gestión de Publicaciones de Precios",
      "type": "row"
    },

    {
      "id": 7,
      "title": "Índice de Veracidad (Upvote Ratio)",
