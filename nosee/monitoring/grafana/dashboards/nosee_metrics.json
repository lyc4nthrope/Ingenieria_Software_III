      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green",  "value": 0.85 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(nosee_publications_votes_total{type=\"upvote\"}) / (sum(nosee_publications_votes_total) > 0)",
          "legendFormat": "Upvote Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "Densidad de Evidencia Visual",
      "description": "Sección 3.4.2 — Meta: >60% con foto",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green",  "value": 0.6 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(nosee_publications_with_image_total) / (sum(nosee_publications_created_total) > 0)",
          "legendFormat": "Evidence Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "Publicaciones Creadas (total)",
      "description": "Total acumulado de publicaciones de precios",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(nosee_publications_created_total) or vector(0)",
          "legendFormat": "Publicaciones",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "Contenido Denunciado (total)",
      "description": "Tasa de Contenido Denunciado — Meta: <5% de activas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(nosee_publications_reports_total) or vector(0)",
          "legendFormat": "Reportes",
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "title": "Total de Votos",
      "description": "Upvotes vs Downvotes acumulados",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Downvotes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(nosee_publications_votes_total{type=\"upvote\"}) or vector(0)",
          "legendFormat": "Upvotes",
          "refId": "A"
        },
        {
          "expr": "sum(nosee_publications_votes_total{type=\"downvote\"}) or vector(0)",
          "legendFormat": "Downvotes",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "title": "Votos en el Tiempo",
      "description": "Upvotes vs Downvotes — Velocidad de Consenso Comunitario",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Downvotes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Upvotes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(nosee_publications_votes_total{type=\"upvote\"}[1h])",
          "legendFormat": "Upvotes",
          "refId": "A"
        },
        {
          "expr": "increase(nosee_publications_votes_total{type=\"downvote\"}[1h])",
          "legendFormat": "Downvotes",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 102,
      "title": "Eficiencia de Desempeño — API",
      "type": "row"
    },

    {
      "id": 13,
      "title": "Latencia API — P95 por Endpoint",
      "description": "Sección 3.2 — Meta: <3000ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 5000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red",    "value": 3000 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (increase(nosee_api_request_duration_ms_bucket[24h])))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 103,
      "title": "Proceso 3 — Gestión de Pedido, Optimización de Compra y Ubicación",
      "type": "row"
    },

    {
      "id": 15,
      "title": "Pedidos Confirmados (24h)",
      "description": "Total de pedidos creados en las últimas 24h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(nosee_orders_created_total[24h]))",
          "legendFormat": "Pedidos",
          "refId": "A"
        }
      ]
    },

    {
      "id": 16,
      "title": "Tasa de Abandono — Pedido",
      "description": "Meta: <20% de los flujos iniciados",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 5, "x": 4, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 20 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * sum(increase(nosee_shopping_list_order_abandoned_total[24h])) / (sum(increase(nosee_shopping_list_order_started_total[24h])) > 0)",
          "legendFormat": "% Abandono Pedido",
          "refId": "A"
        }
      ]
    },

    {
      "id": 17,
      "title": "Latencia Optimización — P95",
      "description": "Meta: <5000ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 5, "x": 9, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 10000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
