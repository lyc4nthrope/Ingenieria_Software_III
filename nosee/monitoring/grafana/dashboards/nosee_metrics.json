    {
      "id": 18,
      "title": "Ahorro Promedio — P50",
      "description": "% de ahorro mediano por pedido (meta: >0%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 5, "x": 14, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green",  "value": 15 }
            ]
          },
          "color": { "mode": "thresholds" },
